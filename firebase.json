{
  "functions": [
    {
      "source": "functions",
      "codebase": "gtfs-sync",
      "runtime": "nodejs22"
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "hosting": {
    "public": "out",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": ["firebase.json", "**/.*", "**/node_modules/**"]
  },
  "apphosting": {
    "backends": [
      {
        "backendId": "default",
        "codebase": {
          "root": "."
        }
      }
    ]
  }
}
