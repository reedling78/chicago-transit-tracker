{
  "name": "@ctt/mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --profile preview --platform android --non-interactive",
    "build:ios": "eas build --profile preview --platform ios --non-interactive",
    "bump": "node ./scripts/bump-version.mjs",
    "distribute:android": "pnpm run bump && node --env-file=.env.local ./scripts/distribute.mjs android",
    "distribute:ios": "pnpm run bump && node --env-file=.env.local ./scripts/distribute.mjs ios",
    "distribute": "pnpm run bump && node --env-file=.env.local ./scripts/distribute.mjs android && node --env-file=.env.local ./scripts/distribute.mjs ios",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:snapshots": "jest --updateSnapshot",
    "lint": "eslint && prettier --check .",
    "lint:fix": "eslint --fix && prettier --write .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@ctt/shared": "workspace:*",
    "@gorhom/bottom-sheet": "^5.2.10",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/query-async-storage-persister": "^5.69.0",
    "@tanstack/react-query": "^5.69.0",
    "@tanstack/react-query-persist-client": "^5.69.0",
    "expo": "~54.0.33",
    "expo-apple-authentication": "~8.0.8",
    "expo-auth-session": "~7.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-router": "~6.0.23",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "firebase": "^11.0.0",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.7",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.15.4",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.1",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "eslint": "^9",
    "eslint-config-expo": "~10.0.0",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "jest-expo": "~54.0.0",
    "prettier": "^3.8.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
